@model CVManagementSystem.Models.ViewModels.UserDetailViewModel

@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">User Details</h2>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">First Name</h6>
                            <p class="h5">@Model.FirstName</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Last Name</h6>
                            <p class="h5">@Model.LastName</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Email</h6>
                            <p class="h5">@Model.Email</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Status</h6>
                            @if (Model.IsBlocked)
                            {
                                <p><span class="badge bg-danger">Blocked</span></p>
                            }
                            else
                            {
                                <p><span class="badge bg-success">Active</span></p>
                            }
                        </div>
                    </div>

                    <div class="card mt-4 mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Role Management</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="text-muted mb-3">Current Role: <strong>@Model.CurrentRole</strong></h6>
                            
                            @if (Model.AvailableRoles.Any())
                            {
                                <form method="post" asp-action="AssignRole">
                                    <input type="hidden" name="userId" value="@Model.Id" />
                                    
                                    <div class="mb-3">
                                        <label class="form-label">Assign New Role</label>
                                        <select name="roleName" class="form-select">
                                            <option value="">-- Select a role --</option>
                                            @foreach (var role in Model.AvailableRoles)
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        </select>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Assign Role</button>
                                </form>
                            }
                        </div>
                    </div>

                    <div class="card mt-4 mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Account Control</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <a asp-action="EditProfile" asp-route-userId="@Model.Id" class="btn btn-primary">
                                    <i class="bi bi-pencil"></i> Edit Profile
                                </a>
                            </div>
                            
                            @if (Model.IsBlocked)
                            {
                                <p class="text-warning mb-3">This user account is currently blocked.</p>
                                <form method="post" asp-action="UnblockUser">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success">Unblock User</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-action="BlockUser">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to block this user?');">Block User</button>
                                </form>
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <a asp-action="UserManagement" class="btn btn-secondary">Back to Users</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
