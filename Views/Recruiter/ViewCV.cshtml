@model CVManagementSystem.Models.ViewModels.RecruiterCVDetailViewModel

@{
    ViewData["Title"] = "CV Details - " + Model.CandidateName;
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <!-- Header with Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="CVs">All CVs</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.CandidateName</li>
                </ol>
            </nav>

            <!-- CV Header Card -->
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h3 class="mb-0">@Model.Title</h3>
                            <p class="mb-0 mt-2 opacity-75">
                                <i class="bi bi-person-circle"></i> @Model.CandidateName
                            </p>
                        </div>
                        <div class="col-md-4 text-end">
                            <span class="badge bg-light text-dark">Read-Only View</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Candidate Information -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h5 class="border-bottom pb-2 mb-3">Candidate Information</h5>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">Name</h6>
                            <p class="h6">@Model.CandidateName</p>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">Email</h6>
                            <p class="h6">@Model.CandidateEmail</p>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">Location</h6>
                            <p class="h6">@Model.CandidateLocation</p>
                        </div>
                    </div>

                    <!-- Position Information -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h5 class="border-bottom pb-2 mb-3">Position Details</h5>
                        </div>
                        <div class="col-md-8">
                            <h6 class="text-muted mb-1">Position Title</h6>
                            <p class="h6">
                                <a asp-controller="Positions" asp-action="Details" asp-route-id="@Model.PositionId" 
                                   class="text-decoration-none">
                                    @Model.PositionTitle
                                </a>
                            </p>
                            <p class="text-muted small">@Model.PositionDescription</p>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">CV Created</h6>
                            <p class="h6">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                            <h6 class="text-muted mb-1 mt-3">Last Updated</h6>
                            <p class="h6">@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CV Attributes -->
            @if (Model.Attributes.Any())
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-list-check"></i> CV Attributes
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var attr in Model.Attributes)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 border rounded">
                                        <h6 class="text-primary mb-2">@attr.AttributeName</h6>
                                        <p class="mb-0">@attr.Value</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">CV Attributes</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-0">No attributes specified for this CV.</p>
                    </div>
                </div>
            }

            <!-- Associated Projects -->
            @if (Model.Projects.Any())
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-folder"></i> Associated Projects
                        </h5>
                    </div>
                    <div class="card-body">
                        @foreach (var project in Model.Projects)
                        {
                            <div class="card mb-3 border-start border-primary border-3">
                                <div class="card-body">
                                    <h6 class="card-title text-primary">@project.Name</h6>
                                    <p class="card-text">@project.Description</p>
                                    @if (!string.IsNullOrEmpty(project.Technologies))
                                    {
                                        <div class="mt-2">
                                            <strong class="text-muted small">Technologies:</strong><br/>
                                            @foreach (var tech in project.Technologies.Split(',').Select(t => t.Trim()))
                                            {
                                                <span class="badge bg-secondary me-1 mb-1">@tech</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Associated Projects</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-0">No projects associated with this CV.</p>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="mt-4 mb-5">
                <a asp-action="CVs" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to All CVs
                </a>
                <a asp-action="PositionCVs" asp-route-positionId="@Model.PositionId" class="btn btn-outline-primary">
                    <i class="bi bi-briefcase"></i> View Other CVs for this Position
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="EditCV" asp-route-cvId="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit CV (Admin)
                    </a>
                }
            </div>
        </div>
    </div>
</div>
