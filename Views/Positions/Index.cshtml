@using CVManagementSystem.Models.Domain

@model List<Position>

@{
    ViewData["Title"] = "Positions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Positions</h1>
    @if (User.IsInRole("Recruiter"))
    {
        <a href="@Url.Action("Create")" class="btn btn-primary">+ New Position</a>
    }
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No positions found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var position in Model)
                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Details", new { id = position.Id })">@position.Title</a>
                        </td>
                        <td>@Html.DisplayText(position.Description.Length > 50 ? position.Description.Substring(0, 50) + "..." : position.Description)</td>
                        <td>@position.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="@Url.Action("Details", new { id = position.Id })" class="btn btn-info">Details</a>
                                <a href="@Url.Action("Edit", new { id = position.Id })" class="btn btn-warning">Edit</a>
                                @if (User.IsInRole("Recruiter") || User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Recruiter" asp-action="PositionCVs" asp-route-positionId="@position.Id" 
                                       class="btn btn-primary">View CVs</a>
                                }
                                <form method="post" asp-action="Delete" asp-route-id="@position.Id" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger">Delete</button>
                                </form>
                                @if (User.IsInRole("Recruiter"))
                                {
                                    <form method="post" asp-action="Duplicate" asp-route-id="@position.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-info">Duplicate</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
