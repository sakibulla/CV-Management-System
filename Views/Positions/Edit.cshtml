@using CVManagementSystem.Models.Domain

@model Position

@{
    ViewData["Title"] = "Edit Position";
    var positionId = Model.Id;
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h2 class="mb-0">Edit Position</h2>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @Html.ValidationSummary(false)
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Edit" asp-route-id="@positionId">
                        <div class="mb-3">
                            <label for="title" class="form-label">Position Title *</label>
                            <input type="text" id="title" name="title" class="form-control" value="@Model.Title" placeholder="e.g., Senior Software Engineer" required>
                            <small class="form-text text-muted">Enter the job position title</small>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Description *</label>
                            <textarea id="description" name="description" class="form-control" rows="5" placeholder="Enter a detailed job description" required>@Model.Description</textarea>
                            <small class="form-text text-muted">Describe the job responsibilities and requirements</small>
                        </div>

                        <div class="mb-3">
                            <label for="Attributes" class="form-label">Select Attributes *</label>
                            <div id="attributesList">
                                @if (ViewData["Attributes"] != null)
                                {
                                    var multiSelectList = (Microsoft.AspNetCore.Mvc.Rendering.MultiSelectList)ViewData["Attributes"];
                                    @if (multiSelectList.Count() > 0)
                                    {
                                        var selectedIds = Model.Attributes.Select(a => a.Id).ToArray();
                                        <div class="form-check-list" style="max-height: 300px; overflow-y: auto; border: 1px solid #dee2e6; padding: 10px; border-radius: 4px;">
                                            @foreach (var item in multiSelectList)
                                            {
                                                var isSelected = selectedIds.Contains(int.Parse(item.Value));
                                                <div class="form-check">
                                                    @if (isSelected) {
                                                        <input class="form-check-input" type="checkbox" name="selectedAttributeIds" value="@item.Value" id="attr_@item.Value" checked />
                                                    } else {
                                                        <input class="form-check-input" type="checkbox" name="selectedAttributeIds" value="@item.Value" id="attr_@item.Value" />
                                                    }
                                                    <label class="form-check-label" for="attr_@item.Value">
                                                        @item.Text
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning">
                                            No attributes available. <a href="@Url.Action("Create", "Attributes")">Create an attribute first</a>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        No attributes available. <a href="@Url.Action("Create", "Attributes")">Create an attribute first</a>
                                    </div>
                                }
                            </div>
                            <small class="form-text text-muted">Select at least one attribute for this position</small>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

